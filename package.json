{
  "name": "hydraterm",
  "version": "0.0.1",
  "description": "A Bun-native terminal process dashboard with real VT fidelity. Early work in progress.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vestia-dev/hydraterm.git"
  },
  "bin": {
    "hydraterm": "./bin/hydraterm"
  },
  "files": [
    "bin/hydraterm",
    "native/darwin-arm64/libghostty-vt.dylib",
    "README.md"
  ],
  "type": "module",
  "os": ["darwin"],
  "cpu": ["arm64"],
  "license": "MIT",
  "scripts": {
    "build": "bun build --compile --outfile bin/hydraterm index.ts",
    "demo:spinner": "i=0; while [ $i -lt 20 ]; do printf '\\r\\033[2K⠋ Building'; sleep 0.05; printf '\\r\\033[2K⠹ Done'; sleep 0.05; i=$((i + 1)); done; printf '\\n'",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.4.3",
    "@opentui/react": "^0.4.3",
    "react": "^19.2.7"
  }
}
